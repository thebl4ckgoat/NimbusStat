table Callers
	lineageTag: 6ed0787b-2274-4b31-bada-b1389debfc28

	measure '% Appels répétés' =
			
			VAR _Seuil = 3
			VAR _Recurrents =
			    CALCULATETABLE (
			        VALUES ( Callers[Caller] ),
			        FILTER ( VALUES ( Callers[Caller] ), [ΣTotalSessions] >= _Seuil )
			    )
			RETURN
			DIVIDE (
			    CALCULATE ( [ΣTotalSessions], _Recurrents ),
			    [ΣTotalSessions]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 66a20854-594a-4f74-8918-171326f43757

	measure 'Titre (Part d''appels répétés)' = "Pourcentage du volume total d'appels provenant d'appelants ayant contacté le service au moins 3 fois sur la période."
		lineageTag: 71b75f84-81af-407e-81e9-a3ec70336a80

