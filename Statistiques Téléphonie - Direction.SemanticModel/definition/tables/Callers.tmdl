	partition Callers-b6e432b4-79e9-4481-8e32-cbaf53abd441 = m
		mode: import
		queryGroup: Dimensions
		source = ```
				let
				    Source = GlobalSource,
				    Callers_table = Source{[Name="Callers",Signature="table"]}[Data],
				    StopFolding = Table.StopFolding(Callers_table),
				    #"Renamed Id" = Table.RenameColumns(StopFolding,{{"Id", "CallerId"}}),
				    #"Renamed CustomerIdentifier" = Table.RenameColumns(#"Renamed Id",{{"CustomerIdentifier", "Caller"}}),
				    OriginType = Table.AddColumn(#"Renamed CustomerIdentifier", "OriginType", each 
				        if [TelNumber] <> null then "PSTN" 
				        else if [O365Id] <> null then "INTL" 
				        else "UNKN"
				        )        
				in
				    OriginType
				```

	annotation PBI_ResultType = Table

