				//2. then add the required data transformations
				
				//add End and Start converted into Local timezone so that they can be used for calculations using the time zone selected in the parameters by the user
				    ,#"Inserted Local Start" = Table.AddColumn(UserStates, "StartLocal", each ToLocalDateTimeZone([Start]), type datetimezone),
				    #"Inserted Local End" = Table.AddColumn(#"Inserted Local Start", "EndLocal", each ToLocalDateTimeZone([End]), type datetimezone),
