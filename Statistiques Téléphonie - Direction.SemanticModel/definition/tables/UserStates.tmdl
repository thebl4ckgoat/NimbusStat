table UserStates
	lineageTag: d511b82d-7966-405c-8659-3082dad19dd9

	refreshPolicy
		policyType: basic
		rollingWindowGranularity: year
		rollingWindowPeriods: 1
		incrementalGranularity: day
		incrementalPeriods: 1
		sourceExpression = ```
			//1. first evaluate whether the User Startes table should be loaded with data or not
			let
			    UserStates = 
			    
			if #"Load User States" = true then
			    
			    let
			        Source = GlobalSource,
			        UserStates_table0 = Source{[Name="UserStates",Signature="table"]}[Data], 
			        #"Filtered Rows" = Table.SelectRows(UserStates_table0, each ([Start] >= DateTime.AddZone(RangeStart,0) and [Start] < DateTime.AddZone(RangeEnd,0))) 
			    in
			    #"Filtered Rows"
			     
			else
			    #"EmptyUserStatesTable"
			
			//2. then add the required data transformations
			
			//add End and Start converted into Local timezone so that they can be used for calculations using the time zone selected in the parameters by the user
			    ,#"Inserted Local Start" = Table.AddColumn(UserStates, "StartLocal", each ToLocalDateTimeZone([Start]), type datetimezone),
			    #"Inserted Local End" = Table.AddColumn(#"Inserted Local Start", "EndLocal", each ToLocalDateTimeZone([End]), type datetimezone),
			    #"TableWithDuration" = Table.AddColumn(#"Inserted Local End", "PeriodLength", each [EndLocal]-[StartLocal]),
			    #"Inserted Seconds" = Table.AddColumn(#"TableWithDuration", "Second", each Duration.Seconds([PeriodLength]), type number),
			    #"Inserted Minutes" = Table.AddColumn(#"Inserted Seconds", "Minute", each Duration.Minutes([PeriodLength]), type number),
			    #"Inserted Hours" = Table.AddColumn(#"Inserted Minutes", "Hour", each Duration.Hours([PeriodLength]), type number),
			    #"Inserted Days" = Table.AddColumn(#"Inserted Hours", "Day", each Duration.Days([PeriodLength]), type number),
			    #"Inserted Total Seconds" = Table.AddColumn(#"Inserted Days", "Total Seconds", each Duration.TotalSeconds([PeriodLength]), type number),
			    #"Inserted Total Minutes" = Table.AddColumn(#"Inserted Total Seconds", "Total Minutes", each Duration.TotalMinutes([PeriodLength]), type number),
			    #"Inserted Total Hours" = Table.AddColumn(#"Inserted Total Minutes", "Total Hours", each Duration.TotalHours([PeriodLength]), type number),
			    #"Add Date" = Table.AddColumn(#"Inserted Total Hours", "Date", each DateTime.Date([StartLocal]), type date)
			    ,#"Added Start-EndLocal" = Table.AddColumn(#"Add Date", "Start-EndLocal", each Text.Combine({ Text.From(DateTime.From(DateTimeZone.RemoveZone([StartLocal]))), Text.From(DateTime.From (DateTimeZone.RemoveZone([EndLocal])))}, " - "))
			in
			    #"Added Start-EndLocal"
			```

	measure ΣDurationSeconds = SUM(UserStates[Total Seconds])
		lineageTag: cb9a670c-cdb9-4387-b023-42d969d46cdf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ΣDuration_HHMMSS =
			
			IF (NOT ISBLANK ([ΣDurationSeconds]), //show blank instead of empty string
			    IF(INT([ΣDurationSeconds])>=86400, FORMAT (QUOTIENT(INT([ΣDurationSeconds]),86400), "00" ) & "d ") //[DAYS]
			  & FORMAT(QUOTIENT(MOD(INT([ΣDurationSeconds]), 86400),3600), "00" ) & ":" //HOURS
			 & FORMAT(QUOTIENT(MOD(INT([ΣDurationSeconds]), 3600),60), "00") & ":" //MINUTES
			  & FORMAT(MOD(INT([ΣDurationSeconds]), 60), "00") //SECONDS
			)
		lineageTag: bd36dfe2-0e81-4ca8-89fc-a4330221ddaf

