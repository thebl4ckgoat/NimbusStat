	/// Transfer Type of the transfer that led to the termination of the User session (Successful or Failed)
	/// 
	/// The logic resolves the type (name) for the LastTransferTypeId found in the UserSessions entity using the relationship between UserSessions and TransferSeeeionTypes.
	measure LastTransferDesitinationType = CALCULATE(max (TransferSessionTypes[Name]), USERELATIONSHIP(UserSessions[LastTransferTypeId], TransferSessionTypes[Id]))
		lineageTag: 72366f71-cb2e-4598-bccf-62b71883fc0b

	/// Technical Power BI measure. It provides a flag used to check the presence of Tags and Codes in the Tags and Codes report pages so that irrelevant data can be filtered out.
	measure Tag-CodesCheckUS = COALESCE(Count (UserSessionTagsStrings[UserSessionId]), Count(UserSessions[PrimaryCodeId]), Count(UserSessions[SecondaryCodeId]))
		formatString: 0
		lineageTag: 21b04ca2-f983-4981-a244-78aa038154d5

	measure '% Taux d''occupation' =
			
			DIVIDE (
			    [ΣConnectedSeconds],
			    [ΣConnectedSeconds] + [ΣSelectableSeconds]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 89fb9721-07be-4dea-bc90-179fc54d0c78

	measure '% Taux d''occupation (avec ACW)' =
			
			CALCULATE (
			    DIVIDE (
			        [ΣConnectedSeconds] + [ΣACWSeconds],
			        [ΣConnectedSeconds] + [ΣACWSeconds] + [ΣSelectableSeconds]
			    ),
			    TREATAS ( VALUES ( SessionDates[Date] ),          UserStates[Date] ),
			    TREATAS ( VALUES ( Services[Groupe Téléphonie] ), Users[Groupe] )
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 48d05b6b-0ab9-4f4a-938d-8cf2db7531c3

