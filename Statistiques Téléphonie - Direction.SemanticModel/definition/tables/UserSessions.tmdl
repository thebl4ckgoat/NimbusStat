	/// Sum of ΣTotalUserSessions --> count of user sessions where the  User Session Outcome = "Accepted"
	/// 
	/// 
	/// ΣAcceptedUserSessions =
	/// CALCULATE (
	/// [ΣTotalUserSessions],
	/// FILTER (
	/// VALUES ( UserSessionOutcomes[HandledText]),
	/// UserSessionOutcomes[HandledText] = "Accepted"
	/// )
	/// )
	/// 
	measure ΣAcceptedUserSessions =
			
			CALCULATE (
			    [ΣTotalUserSessions],
			    FILTER (
			        VALUES ( UserSessionOutcomes[HandledText]),
			         UserSessionOutcomes[HandledText] = "Accepted"
			    )
			)
		formatString: 0
		lineageTag: 6903bc01-d97b-4958-9917-dddb66e4fcec

	/// Ratio of accepted user sessions, to the total number of user sessions for this Nimbus user, for the selected period
	/// 
	/// DIVIDE([ Σ AcceptedUserSessions],[ Σ TotalUserSessions])*100
	measure '%Acceptance Rate' = DIVIDE([ΣAcceptedUserSessions],[ΣTotalUserSessions])*100
		formatString: 0.0
		lineageTag: b0fd4ace-e950-4f80-b788-711bc8079039

	/// Count of user sessions for the last 30 days in relation to today's date.
	/// 
	/// Note that if the report itself does not contain the last 30 days of data this KPI will yield a null value.
	measure ΣUserSessions30d =
			
			VAR CurrentDate = TODAY()
			RETURN
			CALCULATE(
			    [ΣTotalUserSessions],
			    DATESBETWEEN(UserSessionDates[Date], CurrentDate - 30, CurrentDate - 1)
			) + 0
		formatString: 0
		lineageTag: 73037581-1910-4b19-acea-fbc963910a64

	/// Counts user sessions in relation to the current system date.
	/// Note: if the report doesn't contain data for today, this measure will yield a null value.
	measure ΣUserSessionsToday =
			
			VAR CurrentDate = TODAY()
			RETURN
			CALCULATE(
			    [ΣTotalUserSessions],
			    UserSessionDates[Date]=CurrentDate
			) + 0
		formatString: 0
		lineageTag: 4869f582-083f-4fc8-a4dd-6b625d341cd7

