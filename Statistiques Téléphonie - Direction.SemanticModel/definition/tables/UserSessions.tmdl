table UserSessions
	lineageTag: 0b555dee-3d69-4be1-a5bc-0e97aec8d621

	refreshPolicy
		policyType: basic
		rollingWindowGranularity: year
		rollingWindowPeriods: 1
		incrementalGranularity: day
		incrementalPeriods: 1
		sourceExpression = ```
			let
			    Source = GlobalSource,
			    UserSessions_table = Source{[Name="UserSessions",Signature="table"]}[Data],
			    #"Filtered Rows" = Table.SelectRows(UserSessions_table, each ([UserSelectedAt] >= DateTime.AddZone(RangeStart,0) and [UserSelectedAt] < DateTime.AddZone(RangeEnd,0))) , // date filter Incr Refresh date parameters
			    
			    #"Inserted Local Time" = Table.AddColumn(#"Filtered Rows", "Local Time", each ToLocalDateTimeZone([UserSelectedAt]), type datetimezone),   
			
			
			    #"Inserted Date" = Table.AddColumn(#"Inserted Local Time", "Date", each DateTime.Date([Local Time]), type date),
			    #"Inserted Time" = Table.AddColumn(#"Inserted Date", "Time", each DateTime.Time([Local Time]), type time),
			    HourCol = Table.AddColumn(#"Inserted Time", "Hours", each Time.Hour([Time]), Int64.Type),
			    MinuteCol = Table.AddColumn(HourCol, "Minutes", each Time.Minute([Time]), Int64.Type),
			    Fixed15Min = Table.AddColumn(MinuteCol,"Fixed15Min",each 
			            if Number.IntegerDivide([Minutes],15) = 0 then Number.ToText([Hours]) & ":00:00"
			            else if Number.IntegerDivide([Minutes],15) = 1 then Number.ToText([Hours]) & ":15:00"
			            else if Number.IntegerDivide([Minutes],15) = 2 then Number.ToText([Hours]) & ":30:00"
			            else Number.ToText([Hours]) & ":45:00"),
			    ConferencedTimeNullto0 = Table.ReplaceValue(Fixed15Min,null,0,Replacer.ReplaceValue,{"ConferencedTime"}),
			    ConsultationTimeNullto0 = Table.ReplaceValue(ConferencedTimeNullto0,null,0,Replacer.ReplaceValue,{"ConsultationTime"}),
			    AcwTimeNullto0 = Table.ReplaceValue(ConsultationTimeNullto0,null,0,Replacer.ReplaceValue,{"AcwTime"}),
			    ConnectedTimeNullto0 = Table.ReplaceValue(AcwTimeNullto0,null,0,Replacer.ReplaceValue,{"ConnectedTime"}),
			    RingTimeNullto0 = Table.ReplaceValue(ConnectedTimeNullto0,null,0,Replacer.ReplaceValue,{"RingTime"}),
			    #"Changed Type" = Table.TransformColumnTypes(RingTimeNullto0,{{"Fixed15Min", type time}})
			in
			    #"Changed Type"
			```

	/// Average connected time expressed in seconds
	measure ØConnectedTimeS = INT(CALCULATE(AVERAGE(UserSessions[ConnectedTime]), UserSessions[ConnectedTime]>0))
		lineageTag: ae5d5a4a-e117-436b-a19e-87fcfee76633

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Average connected time formatted as HH:MM:SS
	measure ØConnectedTime_HHMMSS =
			
			IF (NOT ISBLANK ([ØConnectedTimeS]), //show blank instead of empty string
			    IF(INT([ØConnectedTimeS])>=86400, FORMAT (QUOTIENT(INT([ØConnectedTimeS]),86400), "00" ) & "d ") //[DAYS]
			  & FORMAT(QUOTIENT(MOD(INT([ØConnectedTimeS]), 86400),3600), "00" ) & ":" //HOURS
			 & FORMAT(QUOTIENT(MOD(INT([ØConnectedTimeS]), 3600),60), "00") & ":" //MINUTES
			  & FORMAT(MOD(INT([ØConnectedTimeS]), 60), "00") //SECONDS
			)
		lineageTag: 4d89de4d-b8e4-4199-bdb4-880a24334dd7

