	/// Sum of all service sessions time calculations
	/// 
	/// TotalTime = ServiceSessions[TotalConnectedTime] + ServiceSessions[TotalIvrTime] + ServiceSessions[TotalQueueTime]
	/// + ServiceSessions[AcwTime] + ServiceSessions[DialoutTime]
	column TotalTime = ```
			ServiceSessions[TotalConnectedTime] + ServiceSessions[TotalIvrTime] + ServiceSessions[TotalQueueTime] 
