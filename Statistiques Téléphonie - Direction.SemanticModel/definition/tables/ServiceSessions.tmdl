	column 'Tranche attente' =
			
			VAR s = ServiceSessions[TotalQueueTime]
			RETURN
			SWITCH ( TRUE (),
			    s < 10,  "< 10 s",
			    s < 30,  "10–30 s",
			    s < 60,  "30–60 s",
			    s < 120, "1–2 min",
			    s < 300, "2–5 min",
			    "> 5 min"
			)
		lineageTag: 9f666e05-e6be-4e50-9e90-0ecef74e49a5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Tranche attente (ordre)' =
			
			VAR s = ServiceSessions[TotalQueueTime]
			RETURN SWITCH ( TRUE (), s<10,1, s<30,2, s<60,3, s<120,4, s<300,5, 6 )
		formatString: 0
		lineageTag: c46224a8-1fc4-4306-aec7-efc4afae5046
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

