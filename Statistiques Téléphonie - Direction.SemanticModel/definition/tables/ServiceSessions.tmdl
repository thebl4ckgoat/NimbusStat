	/// Count of service sessions with a total queue time > 0
	/// 
	/// ΣQueuedSessions =
	/// CALCULATE (
	/// [ΣTotalSessions],
	/// FILTER (
	/// VALUES ( ServiceSessions[TotalQueueTime] ),
	/// ServiceSessions[TotalQueueTime]  > 0
	/// )
	/// )
	measure ΣQueuedSessions =
			
			CALCULATE (
			    [ΣTotalSessions],
			    FILTER (
			        VALUES ( ServiceSessions[TotalQueueTime] ),
			         ServiceSessions[TotalQueueTime]  > 0
			    )
			)
		formatString: 0
		lineageTag: 520c8a21-69d1-4656-a5a9-a88f15f63544

	/// Percentage of service sessions with an outcome group equal to "Handled By User"
	/// over the count of queued service sessions (ss with a queue time > 0)
	/// 
	/// %Reachability = DIVIDE([ΣHandledByUser(OG)],[ΣQueuedSessions])*100
	measure %Reachability = DIVIDE([ΣHandledByUser(OG)],[ΣQueuedSessions])*100
		formatString: 0.0
		lineageTag: 7bef6d28-f951-441c-ad82-014d5bb0172a

	/// Count of service sessions with an outcome group = "Handled by User"
	measure ΣHandledByUser(OG) =
			
			CALCULATE (
			    [ΣTotalSessions],
			    FILTER (
			        VALUES ( ServiceSessionOutcomes[OutcomeGroup] ),
			         ServiceSessionOutcomes[OutcomeGroup] = "Handled By User"
			    )
			)
		formatString: 0
		lineageTag: 441bd9a8-cc3c-4925-b174-2e4f237bee87

