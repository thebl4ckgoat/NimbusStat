	/// Logic created to define the text to be shown for a button logic
	measure 'Button Text' =
			
			VAR ValidSelection = ISFILTERED(ServiceSessions[Id])
			VAR Result =
			IF(
			    ValidSelection,
			    "See Session Details",
			    "Select Session"
			)
			RETURN
			    Result
		lineageTag: 4f4aeb0e-acfc-49f6-b4d8-6c00651c774d

		changedProperty = IsHidden

	/// Technical object used for report design to display totals in a multi line.
	measure MultiLineTotal = ```
			
			VAR KPI1_TEXT = "ΣTotal:  " & FORMAT([ΣTotalSessions],"0")
			VAR KPI2_TEXT = "ΣHandledByUser: " & FORMAT([ΣHandledByUser(OG)], "0")
			VAR KPI3_TEXT = "ΣHandledBySystem:  " & FORMAT([ΣHandledBySystem(OG)], "0")
			VAR KPI4_TEXT = "ΣHangupByCustomer:  " & FORMAT([ΣHangupByCustomer(OG)], "0")
