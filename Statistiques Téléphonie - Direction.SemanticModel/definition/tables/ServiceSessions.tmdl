	/// Count of service sessions with an outcome group  equal to "Hangup By Customer" AND a duration below the SLA value set for the service.
	/// 
	/// ΣHangupInQueueSLA =
	/// CALCULATE (
	/// [ΣHangupByCustomer(OG)],
	/// FILTER ( VALUES ( ServiceSessions[IsUnderSla] ), ServiceSessions[IsUnderSla] = TRUE() )
	/// )
	measure ΣHangupInQueueSLA =
			
			CALCULATE (
			    [ΣHangupByCustomer(OG)],
			    FILTER ( VALUES ( ServiceSessions[IsUnderSla] ), ServiceSessions[IsUnderSla] = TRUE() )
			)
