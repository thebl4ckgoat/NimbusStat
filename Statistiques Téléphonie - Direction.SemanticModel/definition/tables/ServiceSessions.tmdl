				    #"Filtered Rows" = Table.SelectRows(ServiceSessions_table, each ([StartedAt] >= DateTime.AddZone(RangeStart,0) and [StartedAt] < DateTime.AddZone(RangeEnd,0))), // date range from parameters with incremental refresh naming convention
				
				    #"Inserted Local Time" = Table.AddColumn(#"Filtered Rows", "Local Time", each ToLocalDateTimeZone([StartedAt]), type datetimezone),
				    #"Inserted Date" = Table.AddColumn(#"Inserted Local Time", "Date", each DateTime.Date([Local Time]), type date),
				    #"Inserted Time" = Table.AddColumn(#"Inserted Date", "Time", each DateTime.Time([Local Time]), type time),
				    HourCol = Table.AddColumn(#"Inserted Time", "Hours", each Time.Hour([Time]), Int64.Type),
				    MinuteCol = Table.AddColumn(HourCol, "Minutes", each Time.Minute([Time]), Int64.Type),
				    Fixed15Min = Table.AddColumn(MinuteCol,"Fixed15Min",each 
				            if Number.IntegerDivide([Minutes],15) = 0 then Number.ToText([Hours]) & ":00:00"
				            else if Number.IntegerDivide([Minutes],15) = 1 then Number.ToText([Hours]) & ":15:00"
				            else if Number.IntegerDivide([Minutes],15) = 2 then Number.ToText([Hours]) & ":30:00"
				            else Number.ToText([Hours]) & ":45:00"),
				    TotalQueueTimeNullto0 = Table.ReplaceValue(Fixed15Min,null,0,Replacer.ReplaceValue,{"TotalQueueTime"}),
				    TotalIvrTimeNullto0 = Table.ReplaceValue(TotalQueueTimeNullto0,null,0,Replacer.ReplaceValue,{"TotalIvrTime"}),
				    TotalConnectedTimeNullto0 = Table.ReplaceValue(TotalIvrTimeNullto0,null,0,Replacer.ReplaceValue,{"TotalConnectedTime"}),
				    AcwTimeNullto0 = Table.ReplaceValue(TotalConnectedTimeNullto0,null,0,Replacer.ReplaceValue,{"AcwTime"}),
				    HoldTimeNullto0 = Table.ReplaceValue(AcwTimeNullto0,null,0,Replacer.ReplaceValue,{"HoldTime"}),
				    #"Changed Type" = Table.TransformColumnTypes(HoldTimeNullto0,{{"Fixed15Min", type time}})
				in
				    #"Changed Type"
				```

