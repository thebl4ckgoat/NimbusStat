	measure 'Pic de charge (heure)' =
			
			VAR _Vol =
			    ADDCOLUMNS ( VALUES ( ServiceSessions[Hours] ), "@Vol", [ΣTotalSessions] )
			VAR _Max = MAXX ( _Vol, [@Vol] )
			RETURN
			    CONCATENATEX (
			        FILTER ( _Vol, [@Vol] = _Max ),
			        FORMAT ( ServiceSessions[Hours], "0" ) & "h",
			        " / ",
			        ServiceSessions[Hours], ASC
			    )
		lineageTag: fde4d1f6-6488-4fd8-9ec2-14e7f6644992

	measure 'Pic de charge' =
			
			VAR _Vol = ADDCOLUMNS ( VALUES ( ServiceSessions[Hours] ), "@Vol", [ΣTotalSessions] )
			VAR _Max = MAXX ( _Vol, [@Vol] )
			VAR _Heure =
			    CONCATENATEX ( FILTER ( _Vol, [@Vol] = _Max ),
			        FORMAT ( ServiceSessions[Hours], "0" ) & "h", " / ", ServiceSessions[Hours], ASC )
			RETURN
			    _Heure & " (" & FORMAT ( _Max, "#,0" ) & " appels)"
		lineageTag: 7617b967-5c9d-46aa-ab0d-11de5f918675

	measure 'Pic de charge (jour+heure)' =
			
			VAR _Grid =
			    ADDCOLUMNS (
			        SUMMARIZE ( ServiceSessions, SessionDates[DayOfWeekName], ServiceSessions[Hours] ),
			        "@Vol", [ΣTotalSessions]
			    )
			VAR _Max = MAXX ( _Grid, [@Vol] )
			RETURN
			    CONCATENATEX ( FILTER ( _Grid, [@Vol] = _Max ),
			        SessionDates[DayOfWeekName] & " " & FORMAT ( ServiceSessions[Hours], "0" ) & "h", " / " )
		lineageTag: 2d5429a0-e114-436c-974c-9ee85f7b35b1

	measure 'Pic charge (titre)' = "Tranche horaire qui concentre le plus grand nombre d'appels sur la période sélectionnée."
		lineageTag: 7ee6b634-a4be-4be2-9b98-fb38341d60d8

	measure 'Moyenne appels / heure' =
			
			DIVIDE (
			    [ΣTotalSessions],
			    COUNTROWS (
