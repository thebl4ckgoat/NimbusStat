		lineageTag: 8b77c296-7209-4817-926a-3194f823cfd9

	/// Count of service sessions with an outcome that is flagged as MeansHandled = TRUE
	measure ΣHandledSessions =
			
			CALCULATE (
			    [ΣTotalSessions],
			    FILTER (
			        VALUES ( ServiceSessionOutcomes[MeansHandled] ),
			         ServiceSessionOutcomes[MeansHandled] = TRUE()
			    )
			)
		formatString: 0
		lineageTag: c0316520-6634-4290-b147-be1470a1a7c3

	/// Count of service sessions with an outcome group = "Handled by User" AND IsUnderSLA = TRUE
	measure ΣHandledByUserSLA =
			
			CALCULATE (
			    [ΣHandledByUser(OG)],
			    FILTER ( VALUES ( ServiceSessions[IsUnderSla] ), ServiceSessions[IsUnderSla] = TRUE() )
			)
		formatString: 0
		lineageTag: 0a31a001-64c3-438e-9e39-d6a47706edbd

	/// Percentage of the service sessions handled by user(s) that were handled within the SLA time set for the service associated with the session.
	/// 
	/// %AcceptanceSLA = DIVIDE([ΣHandledByUserSLA],[ΣHandledByUser(OG)]) * 100
	measure %AcceptanceSLA = DIVIDE([ΣHandledByUserSLA],[ΣHandledByUser(OG)]) * 100
		formatString: 0.0
		lineageTag: 813962c4-697a-40c9-9ab1-87726e63f84a

	/// Count of service sessions with a MeansHandled flag = FALSE
	measure ΣNotHandledSessions =
			
			CALCULATE (
			    [ΣTotalSessions],
			    FILTER (
			        VALUES ( ServiceSessionOutcomes[MeansHandled] ),
			         ServiceSessionOutcomes[MeansHandled] = FALSE()
			    )
			)
		formatString: 0
		lineageTag: 0e7a6000-fec2-45a2-88f1-637887e095a4

	/// Percentage of service sessions that have an outcome equal to handled, out of all selected service sessions
	measure '%Handled Rate' = IF(ISBLANK([ΣHandledSessions]) && [ΣTotalSessions]>0, 0, DIVIDE([ΣHandledSessions],[ΣTotalSessions])*100)
		formatString: 0.0
		lineageTag: 7862b369-0c2f-4c8d-ba01-3a17ed94137f

