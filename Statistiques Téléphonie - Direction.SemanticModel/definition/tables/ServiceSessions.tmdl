	/// Count of service sessions where outcome is IN
	/// "Customer Hangup In Ivr"
	/// OR
	/// "Customer Hangup In Ivr After Queue"
	measure ΣCustomerHangupInQueue(Outcome) =
			
			CALCULATE (
			    [ΣTotalSessions],
			    FILTER (
			        VALUES ( ServiceSessionOutcomes[Outcome] ),
			         ServiceSessionOutcomes[Outcome] IN {"Customer Hangup In Queue", "Customer Hangup In Ivr After Queue"}
			    )
			)
		formatString: 0
