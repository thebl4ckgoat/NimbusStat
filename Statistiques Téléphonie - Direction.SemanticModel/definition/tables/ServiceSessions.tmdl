table ServiceSessions
	lineageTag: c68f83d6-9fa8-4371-be9c-aec45e8c3549

	refreshPolicy
		policyType: basic
		rollingWindowGranularity: year
		rollingWindowPeriods: 1
		incrementalGranularity: day
		incrementalPeriods: 1
		sourceExpression = ```
			let
			    Source = GlobalSource, // source from odata preview
			    
			    ServiceSessions_table = Source{[Name="ServiceSessions",Signature="table"]}[Data],
			    #"Filtered Rows" = Table.SelectRows(ServiceSessions_table, each ([StartedAt] >= DateTime.AddZone(RangeStart,0) and [StartedAt] < DateTime.AddZone(RangeEnd,0))), // date range from parameters with incremental refresh naming convention
			
			    #"Inserted Local Time" = Table.AddColumn(#"Filtered Rows", "Local Time", each ToLocalDateTimeZone([StartedAt]), type datetimezone),
			    #"Inserted Date" = Table.AddColumn(#"Inserted Local Time", "Date", each DateTime.Date([Local Time]), type date),
			    #"Inserted Time" = Table.AddColumn(#"Inserted Date", "Time", each DateTime.Time([Local Time]), type time),
			    HourCol = Table.AddColumn(#"Inserted Time", "Hours", each Time.Hour([Time]), Int64.Type),
			    MinuteCol = Table.AddColumn(HourCol, "Minutes", each Time.Minute([Time]), Int64.Type),
			    Fixed15Min = Table.AddColumn(MinuteCol,"Fixed15Min",each 
			            if Number.IntegerDivide([Minutes],15) = 0 then Number.ToText([Hours]) & ":00:00"
			            else if Number.IntegerDivide([Minutes],15) = 1 then Number.ToText([Hours]) & ":15:00"
			            else if Number.IntegerDivide([Minutes],15) = 2 then Number.ToText([Hours]) & ":30:00"
			            else Number.ToText([Hours]) & ":45:00"),
			    TotalQueueTimeNullto0 = Table.ReplaceValue(Fixed15Min,null,0,Replacer.ReplaceValue,{"TotalQueueTime"}),
			    TotalIvrTimeNullto0 = Table.ReplaceValue(TotalQueueTimeNullto0,null,0,Replacer.ReplaceValue,{"TotalIvrTime"}),
			    TotalConnectedTimeNullto0 = Table.ReplaceValue(TotalIvrTimeNullto0,null,0,Replacer.ReplaceValue,{"TotalConnectedTime"}),
			    AcwTimeNullto0 = Table.ReplaceValue(TotalConnectedTimeNullto0,null,0,Replacer.ReplaceValue,{"AcwTime"}),
			    HoldTimeNullto0 = Table.ReplaceValue(AcwTimeNullto0,null,0,Replacer.ReplaceValue,{"HoldTime"}),
			    #"Changed Type" = Table.TransformColumnTypes(HoldTimeNullto0,{{"Fixed15Min", type time}})
			in
			    #"Changed Type"
			```

	/// Count of service sessions
	measure ΣTotalSessions = COUNT(ServiceSessions[Id])
		formatString: 0
		lineageTag: 9b36d717-d6fc-4b2f-91d2-99ddbdf10a28

	/// Sum of the TotalQueueTime (seconds)
	measure ΣQueueTime = SUM(ServiceSessions[TotalQueueTime])
		lineageTag: 5eff2c14-4faf-41a0-9a67-0b4b4b8a6f11

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Total queue time (ΣQueueTime) formatted as HH:MM:SS
	measure ΣQueueTime_HHMMSS =
			
			IF (NOT ISBLANK ([ΣQueueTime]), //show blank instead of empty string
			    IF(INT([ΣQueueTime])>=86400, FORMAT (QUOTIENT(INT([ΣQueueTime]),86400), "00" ) & "d ") //[DAYS]
			  & FORMAT(QUOTIENT(MOD(INT([ΣQueueTime]), 86400),3600), "00" ) & ":" //HOURS
			 & FORMAT(QUOTIENT(MOD(INT([ΣQueueTime]), 3600),60), "00") & ":" //MINUTES
			  & FORMAT(MOD(INT([ΣQueueTime]), 60), "00") //SECONDS
			)
		lineageTag: ff0d7212-4e8a-41de-a26f-88b15fc87670

	/// Sum of the total connected time (seconds) meant as the total time during which the customer was connected to the user.
	measure ΣTotalConnectedTime = SUM(ServiceSessions[TotalConnectedTime])
		lineageTag: fb3baf3e-8f38-4098-825b-f996f580c3f8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Total connected time formatted as HH:MM:SS
	measure ΣTotalConnectedTime_HHMMSS =
			
			IF (NOT ISBLANK ([ΣTotalConnectedTime]), //show blank instead of empty string
			    IF(INT([ΣTotalConnectedTime])>=86400, FORMAT (QUOTIENT(INT([ΣTotalConnectedTime]),86400), "00" ) & "d ") //[DAYS]
			  & FORMAT(QUOTIENT(MOD(INT([ΣTotalConnectedTime]), 86400),3600), "00" ) & ":" //HOURS
			 & FORMAT(QUOTIENT(MOD(INT([ΣTotalConnectedTime]), 3600),60), "00") & ":" //MINUTES
			  & FORMAT(MOD(INT([ΣTotalConnectedTime]), 60), "00") //SECONDS
			)
		lineageTag: 561f8550-f844-4c91-8d7d-c3876e610b85

