expression CreateTimeTable = ```
		let CreateTimeTable = () as table =>  
		    let
		        SecList = {0..86399},
		        SecTable = Table.FromList(SecList, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
		        SecType = Table.TransformColumnTypes(SecTable,{{"Column1", Int64.Type}}),
		        SecName = Table.RenameColumns(SecType,{{"Column1", "Second"}}),
		        TimeDurCol = Table.AddColumn(SecName,"TimeDuration", each #duration(0,0,0,[Second]), type duration),
		        TimeCol = Table.AddColumn(TimeDurCol, "TimeOfDay", each #time(Duration.Hours([TimeDuration]),Duration.Minutes([TimeDuration]),Duration.Seconds([TimeDuration])), type time),
		        HourCol = Table.AddColumn(TimeCol, "Hours", each Time.Hour([TimeOfDay]), Int64.Type),
		        MinuteCol = Table.AddColumn(HourCol, "Minutes", each Time.Minute([TimeOfDay]), Int64.Type),
		        SecondCol = Table.AddColumn(MinuteCol, "Seconds", each Time.Second([TimeOfDay]), Int64.Type),
		        Fixed15Min = Table.AddColumn(SecondCol,"Fixed15Min",each 
		            if Number.IntegerDivide([Minutes],15) = 0 then Number.ToText([Hours]) & ":00:00"
		            else if Number.IntegerDivide([Minutes],15) = 1 then Number.ToText([Hours]) & ":15:00"
		            else if Number.IntegerDivide([Minutes],15) = 2 then Number.ToText([Hours]) & ":30:00"
		            else Number.ToText([Hours]) & ":45:00"),
		        RemoveTimeDurationCol = Table.RemoveColumns(Fixed15Min,{"TimeDuration"})  
		    in
		        RemoveTimeDurationCol
		in
		  CreateTimeTable
		```
	lineageTag: ea3f5629-272e-4df7-b80a-15ba7496aed3
	queryGroup: Functions

