expression ToLocalDateTimeZone = ```
		let ToLocalDateTimeZone = (UTCDateTimeZone as datetimezone) as datetimezone =>
		  let
		
		  UTC_Date = Date.From(UTCDateTimeZone), // get date format from input parameter to use in logic below
		
		 // set the variables that indicate when summer time starts and ends
		  StartSummerTimeEU  = Date.StartOfWeek(#date(Date.Year(UTC_Date), 3, 31), Day.Sunday), //start of the EU summer time, every last sunday in March
		  EndWinterTimeEU  = Date.StartOfWeek(#date(Date.Year(UTC_Date), 10, 31), Day.Sunday), // end of the EU summer time, every last Sunday in October
		
		  StartSummerTimeUS  = Date.StartOfWeek(#date(Date.Year(UTC_Date), 3, 14), Day.Sunday), //start of the US summer time (general), every year on second Sunday in March
		  EndWinterTimeUS  = Date.StartOfWeek(#date(Date.Year(UTC_Date), 11, 7), Day.Sunday), // US summer time (general) ends on the first Sunday in November
		
		 
		//start logic
		
		 _offset = if Timezone = "(UTC) Coordinated Universal Time" then Record.FromList({0, 0}, {"Hours", "Minutes"}) // if the selecetd time zone is UTC then offset is 0
		
		   
		   else
		   
		      // get the values for the timezone conversion based on the selected timezone (CurrentTimeZone)
		      let _row = Table.First(CurrentTimeZone), // timezone selected in the parameters and stored in the CurrentTimeZone query
		          _stdOffsetHours = Record.Field(_row, "Hours"),
		          _std = Record.FromList({Record.Field(_row, "Hours"), Record.Field(_row, "Minutes")}, {"Hours", "Minutes"}), // extract the hours, time and minutes for the selected time zone to use for applying the time zone conversion
		          _add1Hour = Record.FromList({Record.Field(_row, "Hours") + 1, Record.Field(_row, "Minutes")}, {"Hours", "Minutes"}), // add one hour to the offset used for the conversion to the selected local timezone
		          _off =  if Record.Field(_row, "SupportsDaylightSavingTime") = false then _std // if the selected time zone doesn't support summer time, then go straight to using the standard time for that time zone 
		          
		
		                  else 
		                        if Record.Field(_row, "Hours") > -3 
		                        then 
		                     
		                     //European summer time // logic: set the hour the summer time should switch and add the local time offeset to see when the switch time is reached in local time
		                        if    (UTCDateTimeZone >= #datetimezone(Date.Year(StartSummerTimeEU), Date.Month(StartSummerTimeEU), Date.Day(StartSummerTimeEU), 1 +Number.Abs(_stdOffsetHours), 0, 0, 0, 0) and UTCDateTimeZone <= #datetimezone(Date.Year(EndWinterTimeEU), Date.Month(EndWinterTimeEU), Date.Day(EndWinterTimeEU), 2, 0, 0, 0, 0)) //summer time EU
		                        then  _add1Hour 
		                        else //winter time
		                              _std
		
		                      else
		                        //USA summer time (-5) // logic: set the hour the summer time should switch and add the local time offeset to see when the switch time is reached in local time
		                     if (UTCDateTimeZone >= #datetimezone(Date.Year(StartSummerTimeUS), Date.Month(StartSummerTimeUS), Date.Day(StartSummerTimeUS), 2 + Number.Abs(_stdOffsetHours), 0, 0, 0, 0) and UTCDateTimeZone <= #datetimezone(Date.Year(EndWinterTimeUS), Date.Month(EndWinterTimeUS), Date.Day(EndWinterTimeUS), 1 + Number.Abs(_stdOffsetHours), 0, 0, 0, 0)) //summer time US
		                        then  _add1Hour 
		                        else //winter time
		                              _std    
		      in  _off,
		    _localtime = DateTimeZone.SwitchZone(UTCDateTimeZone, Record.Field(_offset, "Hours"), Record.Field(_offset, "Minutes"))
		  in
		    _localtime
		in 
		  ToLocalDateTimeZone
		```
	lineageTag: 1e71b8d5-66b3-486d-8c41-d4123c23dbef
	queryGroup: Functions

